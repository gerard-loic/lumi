{

    "app" : {
       "name" : "Nom du service",
       "description" : "Description du service",
       "allowed_cors_ips" : ["*"],
       "allowed_cors_methods" : ["*"],
       "allowed_cors_headers" : ["*"],
       "url" : "https://service.fr",
       "ws_inactivity_timeout" : 300,
       "admin_users" : [
            {
                "username" : "",
                "password" : ""
            }
       ]
    },

    "authentication" : {
        "service" : "apiservice",
        "jwt_secret" : "",
        "jwt_algorithm": "HS256",
        "session_duration" : 3600
    },

    "services" : {
        "nexora" : {
            "handler" : "LumePackAPI",
            "url" : "http://api.exemple.local",
            "timeout" : 60
        },
        "bdd" : {
            "handler" : "PostgreSQL",
            "host" : "0.0.0.0",
            "port" : 5432,
            "database" : "dbname",
            "username" : "",
            "password" : ""
        }
    },

    "logger" : {
        "output" : {
            "enabled" : true
        },
        "file" : {
            "enabled" : true,
            "path": "logs"
        }
    },

    "llm" : {
        "system_prompt_file" : "config/systemprompt.md",
        "connector" : "LiteLLM",
        "memory_messages" : 5,
        "empty_llm_response_max_retry" : 2,
        "max_tokens_month" : -1,
        "max_requests_month" : -1,
        "max_requests_minute" : 5,
        "litellm" : {
            "model" : "openai/openai/gpt-oss-120b",
            "embedding_model" : "openai/Qwen/Qwen3-Embedding-0.6B",
            "api_base" : "https://provider.fr/v1",
            "api_key" : ""
        },
        "filters" : {
            "CodeFilter" : {
            }
        }
    },

    "mcp" : {
        "max_tool_iterations" : 10,
        "native_tools_enabled" : [
            "search_knowledge_base",
            "generer_fichier_excel",
            "generer_fichier_pdf",
            "rechercher_sur_internet",
            "lire_page_web",
            "generer_fichier_word"
        ]
    },

    "files" : {
        "temp_dir" : "temp",
        "local_storage_dir" : "data"
    },

    "rag" : {
        "collection" : "demo",
        "embedding_dim" : 1024,
        "top_k" : 5,
        "chunk_size" : 500,
        "chunk_overlap" : 50,
        "connector" : "PgVector",
        "pgvector" : {
            "table" : "rag_documents"
        }
    },

    "connectors" : {
        "webex" : {
            "enabled": false,
            "bot_token": "",
            "webhook_secret": "",
            "webex_api" : "https://webexapis.com/v1",
            "api_key" : "",
            "allow_group_messages": false
        }
    }

    
}